# 🎮 MINECRAFT SERVER CONFIGURATION
# ============================================

# Minecraft Server Host
# Ví dụ: bloom.pikamc.vn, localhost, 192.168.1.100
# Mặc định: bloom.pikamc.vn
MINECRAFT_SERVER_HOST=bloom.pikamc.vn

# Minecraft Server Port
# Mặc định: 25718
MINECRAFT_SERVER_PORT=25718

# Bot Username (Tên người chơi của bot)
# Mặc định: ice
MINECRAFT_BOT_USERNAME=ice

# Minecraft Version
# Ví dụ: 1.21.4, 1.20.1, 1.19.2, 1.16.5
# Mặc định: 1.21.4
MINECRAFT_VERSION=1.21.4


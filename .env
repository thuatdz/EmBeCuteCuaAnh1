# ⚙️ BOT MINECRAFT CONFIGURATION (.env)
# Cấu hình cho botlolicute.ts

# 🔑 API KEYS
# ============================================

# Groq API Key (Free, Fast LLM Model)
# Lấy từ: https://console.groq.com/keys
# Dùng cho AI chat features
GROQ_API_KEY=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

# 🎮 MINECRAFT SERVER CONFIGURATION
# ============================================

# Minecraft Server Host
# Ví dụ: bloom.pikamc.vn, localhost, 192.168.1.100
# Mặc định: bloom.pikamc.vn
MINECRAFT_SERVER_HOST=bloom.pikamc.vn

# Minecraft Server Port
# Mặc định: 25718
MINECRAFT_SERVER_PORT=25718

# Bot Username (Tên người chơi của bot)
# Mặc định: ice
MINECRAFT_BOT_USERNAME=ice

# Minecraft Version
# Ví dụ: 1.21.4, 1.20.1, 1.19.2, 1.16.5
# Mặc định: 1.21.4
MINECRAFT_VERSION=1.21.4

# 🌐 REPLIT CONFIGURATION (Nếu chạy trên Replit)
# ============================================

# Replit Project Slug (tên dự án)
# Tự động: thường lấy từ environment
REPL_SLUG=workspace

# Replit Owner (chủ sở hữu dự án)
# Tự động: thường lấy từ environment  
REPL_OWNER=xihobel480

# 📝 NOTES:
# - Chỉnh port nếu server sử dụng port khác
# - Kiểm tra version Minecraft khớp với server
# - Authorized players list được load từ file "server.namgt68"
# - Để bot được phép command, thêm tên trong "server.namgt68"
